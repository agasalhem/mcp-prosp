{
  "name": "@agasalhem/mcp-prosp",
  "version": "1.0.0",
  "description": "MCP server for Prosp.ai – 15 tools for LinkedIn outbound automation (stdio & HTTP transports)",
  "type": "module",
  "bin": {
    "mcp-prosp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "keywords": [
    "mcp",
    "prosp",
    "linkedin",
    "outbound",
    "automation",
    "claude",
    "ai"
  ],
  "license": "MIT",
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const f='dist/index.js';const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!/'))fs.writeFileSync(f,'#!/usr/bin/env node\\n'+c);\"",
    "prepublishOnly": "npm run build",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run",
    "inspect": "npx @modelcontextprotocol/inspector node dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "express": "^4.21.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "5.7",
    "vitest": "^3.0.0"
  }
}
